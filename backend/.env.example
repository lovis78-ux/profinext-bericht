# ── Local development ──────────────────────────────────────────────────────────
# Copy this file to .env and adjust as needed.

# Where uploaded + optimised PDFs and the SQLite DB are stored.
# On Railway: set to the Volume mount path, e.g. /data
DATA_DIR=./storage

# SQLite (default). On Railway with a Volume mounted at /data:
# DATABASE_URL=sqlite+aiosqlite:////data/reports.db
DATABASE_URL=sqlite+aiosqlite:///./storage/reports.db

# Comma-separated list of allowed frontend origins.
# Add your Netlify URL once deployed, e.g.:
# CORS_ORIGINS=http://localhost:5173,https://your-app.netlify.app
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Asset overrides (optional – defaults point to backend/assets/)
# DECKBLATT_PATH=/data/assets/Deckblatt.pdf
# DISCLAIMER_PATH=/data/assets/Disclaimer.pdf
# LOGO_JPG_PATH=/data/assets/ProfinalSolar_Logo_RGB.jpg
